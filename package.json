{
  "name": "blackbox-ts",
  "version": "0.1.0-alpha.0",
  "description": "Fetch-first TypeScript provider runtime adapter layer for agent and LLM applications.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "author": "Tyxter",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tyxter-dev/blackbox-ts.git"
  },
  "homepage": "https://github.com/tyxter-dev/blackbox-ts#readme",
  "bugs": {
    "url": "https://github.com/tyxter-dev/blackbox-ts/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./providers/openai": {
      "types": "./dist/providers/openai/index.d.ts",
      "default": "./dist/providers/openai/index.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "default": "./dist/providers/index.js"
    },
    "./providers/anthropic": {
      "types": "./dist/providers/anthropic/index.d.ts",
      "default": "./dist/providers/anthropic/index.js"
    },
    "./providers/gemini": {
      "types": "./dist/providers/gemini/index.d.ts",
      "default": "./dist/providers/gemini/index.js"
    },
    "./providers/xai": {
      "types": "./dist/providers/xai/index.d.ts",
      "default": "./dist/providers/xai/index.js"
    },
    "./providers/openrouter": {
      "types": "./dist/providers/openrouter/index.d.ts",
      "default": "./dist/providers/openrouter/index.js"
    },
    "./providers/openai-compatible": {
      "types": "./dist/providers/openai-compatible/index.d.ts",
      "default": "./dist/providers/openai-compatible/index.js"
    },
    "./providers/echo": {
      "types": "./dist/providers/echo/index.d.ts",
      "default": "./dist/providers/echo/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "default": "./dist/runtime/index.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "default": "./dist/tools/index.js"
    },
    "./output": {
      "types": "./dist/output/index.d.ts",
      "default": "./dist/output/index.js"
    },
    "./persistence": {
      "types": "./dist/persistence/index.d.ts",
      "default": "./dist/persistence/index.js"
    },
    "./observability": {
      "types": "./dist/observability/index.d.ts",
      "default": "./dist/observability/index.js"
    },
    "./workspaces": {
      "types": "./dist/workspaces/index.d.ts",
      "default": "./dist/workspaces/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "default": "./dist/mcp/index.js"
    },
    "./realtime": {
      "types": "./dist/realtime/index.d.ts",
      "default": "./dist/realtime/index.js"
    },
    "./workers": {
      "types": "./dist/workers/index.d.ts",
      "default": "./dist/workers/index.js"
    },
    "./workspace-agents": {
      "types": "./dist/workspace-agents/index.d.ts",
      "default": "./dist/workspace-agents/index.js"
    },
    "./skills": {
      "types": "./dist/skills/index.d.ts",
      "default": "./dist/skills/index.js"
    },
    "./schedules": {
      "types": "./dist/schedules/index.d.ts",
      "default": "./dist/schedules/index.js"
    },
    "./pricing": {
      "types": "./dist/pricing/index.d.ts",
      "default": "./dist/pricing/index.js"
    },
    "./cache": {
      "types": "./dist/cache/index.d.ts",
      "default": "./dist/cache/index.js"
    },
    "./planning": {
      "types": "./dist/planning/index.d.ts",
      "default": "./dist/planning/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "default": "./dist/config/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "default": "./dist/testing/index.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "examples",
    "README.md",
    "CHANGELOG.md",
    "FEATURES.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:examples": "tsc --noEmit -p tsconfig.examples.json",
    "test": "vitest run",
    "test:smoke": "vitest run tests/smoke",
    "lint": "eslint src tests vitest.config.ts --max-warnings=0",
    "format": "prettier --write \"**/*.{ts,js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md,yml,yaml}\"",
    "test:package": "pnpm build && node scripts/catalog-snapshot.mjs --check && node scripts/package-smoke.mjs",
    "generate:parity": "node scripts/update-parity-inventory.mjs && node scripts/generate-parity-matrix.mjs && node scripts/generate-test-crosswalk.mjs",
    "generate:parity:inventory": "node scripts/update-parity-inventory.mjs",
    "generate:parity:matrix": "node scripts/generate-parity-matrix.mjs",
    "generate:parity:crosswalk": "node scripts/generate-test-crosswalk.mjs",
    "generate:parity:python": "node scripts/generate-python-fixtures.mjs",
    "generate:parity:ts": "pnpm build && node scripts/generate-typescript-fixtures.mjs",
    "check:parity": "node scripts/update-parity-inventory.mjs --check && node scripts/check-parity-inventory.mjs && node scripts/generate-parity-matrix.mjs --check && node scripts/generate-test-crosswalk.mjs --check",
    "parity:drift": "node scripts/check-parent-drift.mjs",
    "parity:update-parent-baseline": "node scripts/update-parent-baseline.mjs",
    "parity:python": "pnpm build && node scripts/check-python-parity.mjs",
    "generate:api": "node scripts/public-api-snapshot.mjs",
    "check:api": "node scripts/public-api-snapshot.mjs --check",
    "generate:catalog": "pnpm build && node scripts/catalog-snapshot.mjs",
    "check": "pnpm format:check && pnpm check:parity && pnpm typecheck && pnpm typecheck:examples && pnpm check:api && pnpm lint && pnpm test && pnpm test:package",
    "prepare": "pnpm build",
    "clean": "rm -rf dist coverage *.tsbuildinfo"
  },
  "keywords": [
    "llm",
    "agents",
    "provider",
    "openai",
    "anthropic",
    "gemini",
    "xai",
    "openrouter"
  ],
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.0.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.50.0",
    "vite": "6.4.1",
    "vitest": "4.1.6"
  }
}
